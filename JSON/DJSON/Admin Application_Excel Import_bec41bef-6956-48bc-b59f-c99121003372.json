  "form": {
    "id": "bec41bef-6956-48bc-b59f-c99121003372",
    "name": "frmImportUsers",
    "fields": {
      "Label": {
        "name": "Label",
        "type": "none",
        "ext_type": "Label",
        "original_serverid": "Label",
        "original_controltype": "Label",
        "original_bid": "00000000-0000-0000-0000-000000000000",
        "label": "Use  this form to import a user list directly into either EPC or DBP. \r\nIf users will have access to both, we recommend that you import the user list directly into EPC and then use the Synchronization with EPC application to import the list into DBP.",
        "label_bold": false,
        "label_italic": false,
        "label_color": "",
        "tooltip": "The expected file is an Excel document (.xlsx) with the user list on Sheet1.\r\n\r\nThe column headers expected on the first row are:\r\n\r\nUserName, FirstName, MiddleName, LastName, Email, PhoneNumber, Password, Roles(s), Department, Epcadmin, Modeler, Portal, Active, Code, AltCode, Cell, Address, Description"
      },
      "Label2": {
        "name": "Label2",
        "type": "none",
        "ext_type": "Label",
        "original_serverid": "Label2",
        "original_controltype": "Label",
        "original_bid": "00000000-0000-0000-0000-000000000000",
        "label": "An exported user list from the Organization Management application can be used as a template.",
        "label_bold": false,
        "label_italic": false,
        "label_color": "",
        "tooltip": "The column headers on the first row are:\r\n\r\nName, ID, Active, UserCode, Email, Tel, Address, Login, AlternativeCode, FirstName, LastName."
      },
      "Label3": {
        "name": "Label3",
        "type": "none",
        "ext_type": "Label",
        "original_serverid": "Label3",
        "original_controltype": "Label",
        "original_bid": "00000000-0000-0000-0000-000000000000",
        "label": "For a new role, you will need to input the corresponding department. For an existing role, the department is not required.\r\nThe system will disregard a blank or null value under the \u0022Login\u0022 and/or \u0022Username\u0022 columns.\r\n\u2022 If you want to enable EPCAdmin, Modeler, and/or Portal for the user, input \u201CYes\u201D in the relevant fields. If you do not want to enable these permissions, instead leave the columns blank.\r\n\u2022 In the \u0022Active\u0022 column, input \u0022Yes\u0022 to mark the item as active. To mark it as inactive, leave the corresponding row blank.\r\n\u2022 In the Org. Management Excel file, the \u0022Active\u0022 column will instead contain \u0022True\u0022 or \u0022False\u0022 as values. These values will still be accepted by the system.\r\n",
        "label_bold": false,
        "label_italic": false,
        "label_color": ""
      },
      "Label5": {
        "name": "Label5",
        "type": "none",
        "ext_type": "Label",
        "original_serverid": "Label5",
        "original_controltype": "Label",
        "original_bid": "00000000-0000-0000-0000-000000000000",
        "label": "If the list is imported directly into EPC, only the users will be added to the system. You will need to manually link/create the corresponding roles and departments for each user.",
        "label_bold": false,
        "label_italic": false,
        "label_color": ""
      },
